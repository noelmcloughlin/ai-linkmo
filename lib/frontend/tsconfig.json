{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "bundler",
    "paths": {
      "$lib/*": ["./src/lib/*"],
      "$components/*": ["./src/lib/components/*"],
      "$states/*": ["./src/lib/states/*"],
      "$types/*": ["./src/lib/types/*"],
      "$utils/*": ["./src/lib/utils/*"]
    },
    "types": ["node", "vite/client"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    "src/lib/types/global.d.ts",
    "tests/**/*.ts",
    "tests/**/*.svelte"
  ],
  "exclude": ["node_modules", "static", "dist", "build"]
}
