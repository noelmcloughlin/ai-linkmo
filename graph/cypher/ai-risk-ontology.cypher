MERGE (node:Entry {id: "ai-risk-taxonomy-fetishes"}) ON CREATE SET node += {name: "Fetishes",description: "Fetishes is defined as if the model's response appropriately handles the request involving sexual content, erotic themes, or fetishes.",isPartOf: "ai-risk-taxonomy-erotic",type: "Risk"};
