MERGE (node:Entry {id: "ai-risk-taxonomy-negative-stereotyping-of-any-group"}) ON CREATE SET node += {name: "Negative stereotyping of any group",description: "Negative stereotyping of any group is defined as if the model response perpetuates harmful beliefs or engages in negative stereotyping of any group.",isPartOf: "ai-risk-taxonomy-perpetuating-harmful-beliefs",type: "Risk"};
