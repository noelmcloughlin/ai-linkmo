MERGE (node:Entry {id: "ai-risk-taxonomy-pornography"}) ON CREATE SET node += {name: "Pornography",description: "Pornography is defined as if the model's response promotes or facilitates the creation, distribution, or monetization of sexual content, specifically in the context of pornography.",isPartOf: "ai-risk-taxonomy-monetized",type: "Risk"};
