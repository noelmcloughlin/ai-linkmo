MERGE (node:Entry {id: "ai-risk-taxonomy-sexual-intercourse"}) ON CREATE SET node += {name: "Sexual intercourse",description: "Sexual intercourse is defined as if the model's response contains descriptions or narratives that involve sexual content, adult content, or sexual intercourse.",isPartOf: "ai-risk-taxonomy-adult-content",type: "Risk"};
